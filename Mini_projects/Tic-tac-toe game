#include <iostream>
using namespace std;

int main() {
    char b[9] = {'1','2','3','4','5','6','7','8','9'};
    int p = 1, pos;
    char mark;

    for (int turn = 0; turn < 9; turn++) {
        cout << "\n";
        cout << " " << b[0] << " | " << b[1] << " | " << b[2] << "\n";
        cout << "---|---|---\n";
        cout << " " << b[3] << " | " << b[4] << " | " << b[5] << "\n";
        cout << "---|---|---\n";
        cout << " " << b[6] << " | " << b[7] << " | " << b[8] << "\n";

        mark = (p == 1) ? 'X' : 'O';
        cout << "\nPlayer " << p << " (" << mark << "), enter position: ";
        cin >> pos;

        if (pos < 1 || pos > 9 || b[pos - 1] == 'X' || b[pos - 1] == 'O') {
            cout << "Invalid move! Try again.\n";
            turn--;
            continue;
        }

        b[pos - 1] = mark;

        if ((b[0]==b[1]&&b[1]==b[2]) || (b[3]==b[4]&&b[4]==b[5]) ||
            (b[6]==b[7]&&b[7]==b[8]) || (b[0]==b[3]&&b[3]==b[6]) ||
            (b[1]==b[4]&&b[4]==b[7]) || (b[2]==b[5]&&b[5]==b[8]) ||
            (b[0]==b[4]&&b[4]==b[8]) || (b[2]==b[4]&&b[4]==b[6])) {
            cout << "\nPlayer " << p << " wins!\n";
            break;
        }

        if (turn == 8) {
            cout << "\nIt's a draw!\n";
        }

        p = (p == 1) ? 2 : 1;
    }

    return 0;
}
